{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Atomic Rule Schema",
  "description": "JSON schema defining the structure of atomic rules extracted from MD files",
  "type": "object",
  "required": ["rules", "metadata", "coverage_report"],
  "properties": {
    "rules": {
      "type": "array",
      "description": "Array of atomic rules",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "domain",
          "statement",
          "conditions",
          "exceptions",
          "references",
          "coverage",
          "source",
          "version",
          "created_at"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "description": "Unique rule identifier following format RULE-{DOMAIN}-{SEQUENCE}",
            "pattern": "^RULE-[A-Z]{2,4}-\\d{3}(-\\d{2})?$",
            "examples": ["RULE-IM-001", "RULE-IM-001-01"]
          },
          "domain": {
            "type": "string",
            "description": "Business domain abbreviation (2-4 characters)",
            "pattern": "^[A-Z]{2,4}$",
            "examples": ["IM", "RISK", "CALC", "DATA"]
          },
          "structured_id": {
            "type": "string",
            "description": "Structured paragraph ID from MD file",
            "pattern": "^[A-Z]{2,4}-[A-Z]{3,10}-\\d{3}$",
            "examples": ["DC-IMRPF-001", "MRCC-HVaR-001"]
          },
          "statement": {
            "type": "string",
            "description": "Clear, concise rule statement representing a single requirement",
            "minLength": 10,
            "maxLength": 500
          },
          "conditions": {
            "type": "array",
            "description": "List of applicable conditions for the rule",
            "items": {
              "type": "string",
              "minLength": 5
            },
            "default": []
          },
          "exceptions": {
            "type": "array",
            "description": "List of exception cases for the rule",
            "items": {
              "type": "string",
              "minLength": 5
            },
            "default": []
          },
          "references": {
            "type": "array",
            "description": "List of cross-references to related rules or paragraphs",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{2,4}-[A-Z]{3,10}-\\d{3}$"
            },
            "default": []
          },
          "coverage": {
            "type": "string",
            "description": "Coverage status of the rule",
            "enum": ["covered", "not covered"],
            "default": "covered"
          },
          "source": {
            "type": "string",
            "description": "Path to the source MD file",
            "examples": ["docs/source-files/risk-parameters.md"]
          },
          "version": {
            "type": "string",
            "description": "Version of the rule",
            "pattern": "^v\\d+$",
            "examples": ["v14"]
          },
          "created_at": {
            "type": "string",
            "description": "ISO 8601 timestamp when the rule was created",
            "format": "date-time",
            "examples": ["2026-03-18T10:00:00Z"]
          },
          "heading": {
            "type": "string",
            "description": "Heading of the section containing the rule",
            "examples": ["Risk Parameter File Specification"]
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Metadata about the rule extraction process",
      "required": ["total_rules", "covered_rules", "version", "generated_at"],
      "properties": {
        "total_rules": {
          "type": "integer",
          "description": "Total number of rules extracted",
          "minimum": 0
        },
        "covered_rules": {
          "type": "integer",
          "description": "Number of rules that are covered",
          "minimum": 0
        },
        "version": {
          "type": "string",
          "description": "Version of the document from which rules were extracted",
          "pattern": "^v\\d+$",
          "examples": ["v14"]
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp when the rules were generated",
          "format": "date-time",
          "examples": ["2026-03-18T10:00:00Z"]
        },
        "source_directory": {
          "type": "string",
          "description": "Directory containing the source MD files",
          "examples": ["docs/source-files"]
        },
        "schema_version": {
          "type": "string",
          "description": "Version of the JSON schema used",
          "pattern": "^\\d+\\.\\d+$",
          "examples": ["1.0"]
        }
      }
    },
    "coverage_report": {
      "type": "object",
      "description": "Coverage report for all rules",
      "required": ["total_rules", "covered_rules", "coverage_percentage", "generated_at"],
      "properties": {
        "total_rules": {
          "type": "integer",
          "description": "Total number of rules",
          "minimum": 0
        },
        "covered_rules": {
          "type": "integer",
          "description": "Number of covered rules",
          "minimum": 0
        },
        "coverage_percentage": {
          "type": "number",
          "description": "Percentage of rules that are covered",
          "minimum": 0,
          "maximum": 100
        },
        "domain_coverage": {
          "type": "object",
          "description": "Coverage breakdown by domain",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "Total number of rules in the domain",
                "minimum": 0
              },
              "covered": {
                "type": "integer",
                "description": "Number of covered rules in the domain",
                "minimum": 0
              }
            }
          }
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp when the coverage report was generated",
          "format": "date-time",
          "examples": ["2026-03-18T10:00:00Z"]
        }
      }
    }
  },
  "additionalProperties": false
}